# LinkedIn API (https://developer.linkedin.com/apps)
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_URN=

# Content generation uses Claude Code CLI (no API key needed - uses your subscription)

# Google Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=your_newsapi_key

# Slack Notifications (optional — get webhook URL from https://api.slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=
DASHBOARD_URL=http://72.62.231.7:3000

# Reddit Research (no API key needed — uses public .json endpoints)
REDDIT_SUBREDDITS=SaaS,marketing,artificial,webdev,entrepreneur,startups,smallbusiness

# YouTube Data API v3 (enable at https://console.cloud.google.com/apis/library/youtube.googleapis.com)
YOUTUBE_API_KEY=your_youtube_api_key

# Google Custom Search (optional — for Twitter/Quora thread discovery)
# GOOGLE_SEARCH_API_KEY=your_google_search_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id

# Bot Configuration
POST_TIME=09:00
TIMEZONE=America/New_York
INDUSTRY_KEYWORDS=AI,SaaS,software,marketing,ads,machine learning,startups
IMAGE_POST_PERCENTAGE=40
AUTO_POST=true
LINKEDIN_REDIRECT_URI=http://localhost:3456/callback

# LinkedIn API (https://developer.linkedin.com/apps)
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_URN=

# Content generation uses Claude Code CLI (no API key needed - uses your subscription)

# Google Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=your_newsapi_key

# Bot Configuration
POST_TIME=09:00
TIMEZONE=America/New_York
INDUSTRY_KEYWORDS=AI,SaaS,software,marketing,ads,machine learning,startups
IMAGE_POST_PERCENTAGE=40
AUTO_POST=true
LINKEDIN_REDIRECT_URI=http://localhost:3456/callback

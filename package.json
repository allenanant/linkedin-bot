{
  "name": "linkedin-bot",
  "version": "1.0.0",
  "description": "Automated LinkedIn posting bot with AI content generation",
  "main": "dist/index.js",
  "scripts": {
    "setup": "npx tsx scripts/setup-linkedin.ts",
    "run": "npx tsx src/index.ts run",
    "research": "npx tsx src/index.ts research",
    "generate": "npx tsx src/index.ts generate",
    "post": "npx tsx src/index.ts run",
    "schedule": "npx tsx src/index.ts schedule",
    "analytics": "npx tsx src/index.ts analytics",
    "start": "npx tsx src/index.ts schedule",
    "dashboard": "npx tsx src/dashboard/server.ts",
    "build": "tsc && rm -rf dist/dashboard/public && cp -r src/dashboard/public dist/dashboard/public"
  },
  "keywords": [],

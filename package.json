    "google-trends-api": "^4.9.2",
    "node-cron": "^4.2.1",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.19.0",
    "satori": "^0.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
